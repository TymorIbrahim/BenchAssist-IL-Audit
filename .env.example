# BenchAssist-IL environment variables
# Setup:  cp .env.example .env   then edit .env (never commit .env)
#
# Get a Gemini API key: https://aistudio.google.com/apikey

# mock = offline demo (default) | gemini = live Google Gemini calls
MODEL_PROVIDER=mock

# Model ID for the provider (change when switching to gemini)
MODEL_NAME=mock-benchassist

# Paste your Gemini API key here (no quotes). Required when MODEL_PROVIDER=gemini.
GEMINI_API_KEY=

# When using Gemini, also set:
# MODEL_PROVIDER=gemini
# MODEL_NAME=gemini-2.5-flash-lite

TEMPERATURE=0.0
LOG_LEVEL=INFO
