# BenchAssist-IL environment variables
# Setup:  cp .env.example .env   then edit .env (never commit .env)
#
# Get a Gemini API key: https://aistudio.google.com/apikey

# mock = offline demo (default) | gemini = live Google Gemini | openai = optional OpenAI
MODEL_PROVIDER=mock

# Model ID for the provider (change when switching providers)
MODEL_NAME=mock-benchassist

# Use MODEL_PROVIDER=gemini for Gemini runs.
# Use MODEL_NAME=gemini-2.5-flash-lite for low-cost runs (recommended default for Gemini).
# Use MODEL_NAME=gemini-2.5-flash for higher-quality comparison on a smaller sample.

# Paste API keys here (no quotes). Never commit .env to version control.
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

TEMPERATURE=0.0
LOG_LEVEL=INFO
