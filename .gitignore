# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo

# ── Virtual environments ──────────────────────────────────────────────
venv/
.venv/
env/

# ── Distribution / packaging ─────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── Environment variables ─────────────────────────────────────────────
.env
!.env.example

# ── Testing ───────────────────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ── Type checking ─────────────────────────────────────────────────────
.mypy_cache/

# ── Jupyter ───────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── IDE / Editor ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS files ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Project output directories (keep dirs via .gitkeep) ───────────────
results/outputs/*
!results/outputs/.gitkeep

results/tables/*
!results/tables/.gitkeep

results/charts/*
!results/charts/.gitkeep

results/report/*
!results/report/.gitkeep

data/raw/*
!data/raw/.gitkeep

data/processed/*
!data/processed/.gitkeep

data/audit/*
!data/audit/.gitkeep

# ── Large Gemini run outputs (keep analysis CSVs, exclude raw JSONL) ──
results/gemini/*/parsed_outputs.jsonl
results/gemini/*_backup*/
results/gemini/*_backup_*/
results/gemini/*_old_*/
results/gemini/*_partial_*/

# ── Node modules & Next.js build ──────────────────────────────────────
node_modules/
.next/
web_dashboard/node_modules/
web_dashboard/.next/
web_dashboard/.vercel/

# ── Mock outputs ──────────────────────────────────────────────────────
results/mock/*.jsonl

# ── Large raw JSONL outputs ───────────────────────────────────────────
results/gemini/*/raw_responses.jsonl
results/gemini/*/*.jsonl
results/gemini/*/analysis/parsed_synthetic_strict.jsonl
results/preflight/*/analysis/parsed_synthetic_strict.jsonl
results/preflight/*/*.jsonl
